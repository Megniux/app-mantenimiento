rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────
    //
    // El rol y el clienteId del usuario se leen primero desde los custom claims
    // del JWT (gratis: vienen en el token). Si los claims aún no están seteados
    // (usuario antiguo, antes de que la Cloud Function 'syncUserClaims' los
    // sincronice por primera vez), se cae al patrón antiguo de leer
    // users/{uid}. Esto permite migrar sin lockout.

    function tokenRol() {
      return 'rol' in request.auth.token ? request.auth.token.rol : '';
    }

    function tokenClienteId() {
      return 'clienteId' in request.auth.token ? request.auth.token.clienteId : '';
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userRole() {
      return tokenRol() != ''
        ? tokenRol()
        : getUserData().rol;
    }

    function userClienteId() {
      return 'clienteId' in request.auth.token
        ? tokenClienteId()
        : getUserData().clienteId;
    }

    function isSuperadmin() {
      return userRole() == "superadmin";
    }

    function belongsToCliente(clienteId) {
      return userClienteId() == clienteId;
    }

    function hasAccessToCliente(clienteId) {
      return isSuperadmin() || belongsToCliente(clienteId);
    }

    function isAtLeast(rol) {
      let roles = ["usuario", "tecnico", "supervisor", "admin", "superadmin"];
      return userRole() in roles[roles.indexOf(rol):];
    }

    // ── Clientes ─────────────────────────────────────────────────────────────

    match /clientes/{clienteId} {
      allow read, update: if request.auth != null
                           && (isSuperadmin() || belongsToCliente(clienteId));
      allow create, delete: if request.auth != null && isSuperadmin();
    }

    // ── Órdenes ──────────────────────────────────────────────────────────────

    match /ordenes/{doc} {
      allow read: if request.auth != null
                   && hasAccessToCliente(resource.data.clienteId);
      allow create: if request.auth != null
                     && hasAccessToCliente(request.resource.data.clienteId);
      allow update: if request.auth != null
                     && hasAccessToCliente(resource.data.clienteId)
                     && userRole() in ["tecnico", "supervisor", "admin", "superadmin"];
      allow delete: if request.auth != null
                     && hasAccessToCliente(resource.data.clienteId)
                     && userRole() in ["admin", "superadmin"];
    }

    // ── Equipos ──────────────────────────────────────────────────────────────

    match /equipos/{doc} {
      allow read: if request.auth != null
                   && hasAccessToCliente(resource.data.clienteId);
      allow create: if request.auth != null
                     && hasAccessToCliente(request.resource.data.clienteId)
                     && userRole() in ["supervisor", "admin", "superadmin"];
      allow update, delete: if request.auth != null
                              && hasAccessToCliente(resource.data.clienteId)
                              && userRole() in ["supervisor", "admin", "superadmin"];
    }

    // ── Ubicaciones ──────────────────────────────────────────────────────────

    match /ubicaciones/{doc} {
      allow read: if request.auth != null
                   && hasAccessToCliente(resource.data.clienteId);
      allow create: if request.auth != null
                     && hasAccessToCliente(request.resource.data.clienteId)
                     && userRole() in ["supervisor", "admin", "superadmin"];
      allow update, delete: if request.auth != null
                              && hasAccessToCliente(resource.data.clienteId)
                              && userRole() in ["supervisor", "admin", "superadmin"];
    }

    // ── Usuarios ─────────────────────────────────────────────────────────────

    match /users/{uid} {
      allow read: if request.auth != null
                   && (
                     request.auth.uid == uid ||
                     isSuperadmin() ||
                     belongsToCliente(resource.data.clienteId)
                   );
      allow create: if request.auth != null
                     && (
                       isSuperadmin() ||
                       (belongsToCliente(request.resource.data.clienteId)
                        && userRole() in ["admin", "superadmin"])
                     );
      allow update, delete: if request.auth != null
                              && (
                                isSuperadmin() ||
                                (belongsToCliente(resource.data.clienteId)
                                 && userRole() in ["admin", "superadmin"])
                              );
    }

    // ── Repuestos ─────────────────────────────────────────────────────────────
    // Lectura: técnico, supervisor, admin, superadmin del cliente.
    //   - Los técnicos necesitan ver el catálogo para seleccionar repuestos
    //     al cerrar una OT (lo que dispara una solicitudPanol). Sin lectura
    //     no pueden poblar el dropdown del modal de edición.
    // Escritura: supervisor, admin, superadmin (el stock se modifica vía
    //   solicitudes aprobadas, no directamente por el técnico).

    match /repuestos/{doc} {
      allow read: if request.auth != null
                   && hasAccessToCliente(resource.data.clienteId)
                   && userRole() in ["tecnico", "supervisor", "admin", "superadmin"];
      allow create: if request.auth != null
                     && hasAccessToCliente(request.resource.data.clienteId)
                     && userRole() in ["supervisor", "admin", "superadmin"];
      allow update: if request.auth != null
                     && hasAccessToCliente(resource.data.clienteId)
                     && userRole() in ["supervisor", "admin", "superadmin"];
      allow delete: if request.auth != null
                     && hasAccessToCliente(resource.data.clienteId)
                     && userRole() in ["admin", "superadmin"];
    }

    // ── Movimientos de repuestos ──────────────────────────────────────────────
    // Los movimientos son de solo lectura para todos (excepto sistema).
    // Escritura: supervisor, admin, superadmin.
    // Los técnicos no crean movimientos directamente; lo hacen a través de solicitudes.

    match /movimientosRepuestos/{doc} {
      allow read: if request.auth != null
                   && hasAccessToCliente(resource.data.clienteId)
                   && userRole() in ["supervisor", "admin", "superadmin"];
      allow create: if request.auth != null
                     && hasAccessToCliente(request.resource.data.clienteId)
                     && userRole() in ["supervisor", "admin", "superadmin"];
      allow update, delete: if false; // Los movimientos son inmutables
    }

    // ── Solicitudes de pañol ──────────────────────────────────────────────────
    // Creación: técnico, supervisor, admin, superadmin (al registrar consumo en OT).
    // Lectura y aprobación: supervisor, admin, superadmin.

    match /solicitudesPanol/{doc} {
      allow read: if request.auth != null
                   && hasAccessToCliente(resource.data.clienteId)
                   && userRole() in ["supervisor", "admin", "superadmin"];
      allow create: if request.auth != null
                     && hasAccessToCliente(request.resource.data.clienteId)
                     && userRole() in ["tecnico", "supervisor", "admin", "superadmin"];
      allow update: if request.auth != null
                     && hasAccessToCliente(resource.data.clienteId)
                     && userRole() in ["supervisor", "admin", "superadmin"];
      allow delete: if false;
    }
  }
}
