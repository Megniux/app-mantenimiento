rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Función helper: obtiene el rol del usuario autenticado
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isSuperadmin() {
      return getUserData().rol == "superadmin";
    }

    function belongsToCliente(clienteId) {
      return getUserData().clienteId == clienteId;
    }

    function hasAccessToCliente(clienteId) {
      return isSuperadmin() || belongsToCliente(clienteId);
    }

    // Clientes: solo superadmin
  	match /clientes/{clienteId} {
  		allow read, write: if request.auth != null && isSuperadmin();
  		allow read, update: if request.auth != null && belongsToCliente(clienteId);
		}

    // Órdenes, equipos, ubicaciones: acceso por clienteId
    match /ordenes/{doc} {
      allow read, write: if request.auth != null && hasAccessToCliente(resource.data.clienteId);
      allow create: if request.auth != null && hasAccessToCliente(request.resource.data.clienteId);
    }

    match /equipos/{doc} {
      allow read, write: if request.auth != null && hasAccessToCliente(resource.data.clienteId);
      allow create: if request.auth != null && hasAccessToCliente(request.resource.data.clienteId);
    }

    match /ubicaciones/{doc} {
      allow read, write: if request.auth != null && hasAccessToCliente(resource.data.clienteId);
      allow create: if request.auth != null && hasAccessToCliente(request.resource.data.clienteId);
    }

    // Usuarios: admin/superadmin de ese cliente
    match /users/{uid} {
      allow read: if request.auth != null && (
        request.auth.uid == uid ||
        isSuperadmin() ||
        belongsToCliente(resource.data.clienteId)
      );
      allow update, delete: if request.auth != null && (
        isSuperadmin() || belongsToCliente(resource.data.clienteId)
      );
      allow create: if request.auth != null && (
        isSuperadmin() || belongsToCliente(request.resource.data.clienteId)
      );
    }
  }
}